<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Scroll capture redispatches wheel/trackpad events to the source app.
         App Sandbox blocks CGEvent posting across processes, so it stays off. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
